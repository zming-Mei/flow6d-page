---
import { Picture as AstroPicture } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  priority?: boolean;
  invertInDarkMode?: boolean;
}

const { src, alt, priority = false, invertInDarkMode = false } = Astro.props;
---

<AstroPicture
  class={`max-h-[calc(100svh-3rem)] max-w-full w-min mx-auto ${invertInDarkMode ? "dark:invert" : ""}`}
  src={src}
  alt={alt}
  layout="constrained"
  formats={["avif"]}
  priority={priority}
  fit="contain"
/>
